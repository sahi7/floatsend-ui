# API base URL (leave empty in dev to use Vite proxy)
VITE_API_BASE_URL=

# Proxy target for local backend (used by vite.config.ts)
VITE_API_PROXY_TARGET=http://localhost:8080

# Enable X-Debug-Auth header (dev only — returns debug_verify_token etc.)
VITE_DEBUG_AUTH=1

# Platform shared From used in pre-domain test mode (must match API PLATFORM_SHARED_FROM)
VITE_PLATFORM_SHARED_FROM=noreply@mail.floatsend.com
# Comma-separated platform domains allowed for pre-verify From (any local-part)
VITE_PLATFORM_SHARED_DOMAINS=floatsend.com,mail.floatsend.com
